# === Poker Backend Ortam Değişkenleri ===
# Bu dosyayı `.env` olarak kopyalayın ve değerleri doldurun.

# Sunucu portu (varsayılan 5000)
PORT=5000

# JWT imzalama anahtarı — ZORUNLU. Boşsa sunucu başlamaz.
# Güçlü, rastgele bir değer girin (ör: openssl rand -hex 32).
JWT_SECRET=buraya-guclu-rastgele-bir-anahtar-girin

# CORS izin verilen origin. Varsayılan tüm originlere açık (*).
# Deploy'da tek bir adrese kısıtlamak için: CORS_ORIGIN=https://poker.example.com
# Birden çok origin virgülle ayrılabilir: CORS_ORIGIN=https://a.vercel.app,https://b.vercel.app
CORS_ORIGIN=*

# Veritabanı bağlantısı (Supabase/Postgres).
#  - Tanımlıysa Postgres kullanılır (Render gibi efemer diskli host'larda ZORUNLU).
#  - Boş bırakılırsa yerel SQLite dosyasına düşülür (LAN/geliştirme).
# Uzun ömürlü sunucu için Supabase'in "Session pooler" (port 5432) dizesi önerilir.
# Örn: postgresql://postgres.<ref>:<sifre>@aws-0-<bolge>.pooler.supabase.com:5432/postgres
# DATABASE_URL=

# production'da şema alter'ı kapanır ve build tek porttan servis edilir.
# LAN/geliştirme için boş bırakın.
# NODE_ENV=production
